  <main>

<!-- UNIFIED CART SYSTEM - Loads immediately -->
<script>
// ============================================
// DEFINE CART_KEY FIRST - MUST BE AT TOP
// ============================================
const CART_KEY = 'gades_fit_cart';

// ============================================
// CART FUNCTIONS
// ============================================

// Get cart from localStorage
window.getCart = function() {
  try {
    return JSON.parse(localStorage.getItem(CART_KEY)) || [];
  } catch (e) {
    console.error('Error loading cart:', e);
    return [];
  }
};

// Save cart to localStorage
window.saveCart = function(items) {
  localStorage.setItem(CART_KEY, JSON.stringify(items));
  window.updateCartCount();
};

// Update cart count in header
window.updateCartCount = function() {
  const items = window.getCart();
  const count = items.reduce((sum, item) => sum + (item.quantity || 1), 0);
  document.querySelectorAll('.cart-count').forEach(el => {
    el.textContent = count;
    el.style.display = count > 0 ? 'inline-block' : 'none';
  });
};

// Quick Add to Cart - Called from product buttons
window.quickAddToCart = function(btn) {
  console.log('✅ quickAddToCart called!');
  
  const id = btn.getAttribute('data-id');
  const name = btn.getAttribute('data-name');
  const price = btn.getAttribute('data-price');
  const image = btn.getAttribute('data-image') || '';
  const category = btn.getAttribute('data-category') || '';
  
  console.log('Product:', { id, name, price });
  
  if (!id || !name || !price) {
    alert('Cannot add to cart: Missing product information');
    return false;
  }
  
  const items = window.getCart();
  const existingItem = items.find(item => item.id === id);
  
  if (existingItem) {
    existingItem.quantity += 1;
  } else {
    items.push({
      id: id,
      name: name,
      price: parseFloat(price) || 0,
      image: image || '/images/placeholder.jpg',
      category: category || 'Uncategorized',
      color: 'Default',
      size: 'One Size',
      quantity: 1
    });
  }
  
  window.saveCart(items);
  
  // Visual feedback
  const originalText = btn.textContent;
  btn.textContent = 'Added! ✓';
  btn.style.background = '#2D6A4F';
  btn.style.color = 'white';
  btn.disabled = true;
  
  setTimeout(() => {
    btn.textContent = originalText;
    btn.style.background = '';
    btn.style.color = '';
    btn.disabled = false;
  }, 1000);
  
  alert('✨ ' + name + ' added to cart!');
  return true;
};

// Remove item by index
window.removeItemByIndex = function(index) {
  if (confirm('Remove this item from your cart?')) {
    let items = window.getCart();
    items.splice(index, 1);
    window.saveCart(items);
    if (typeof window.renderCart === 'function') {
      window.renderCart();
    }
  }
};

// Update quantity by index
window.updateQuantityByIndex = function(index, change) {
  let items = window.getCart();
  const item = items[index];
  if (item) {
    const newQty = (item.quantity || 1) + change;
    if (newQty >= 1 && newQty <= 99) {
      item.quantity = newQty;
      window.saveCart(items);
      if (typeof window.renderCart === 'function') {
        window.renderCart();
      }
    }
  }
};

// Clear cart
window.clearCart = function() {
  if (confirm('Clear all items from your cart?')) {
    localStorage.removeItem(CART_KEY);
    window.updateCartCount();
    if (typeof window.renderCart === 'function') {
      window.renderCart();
    }
  }
};

// Get subtotal
window.getCartSubtotal = function() {
  const items = window.getCart();
  return items.reduce((sum, item) => sum + ((item.price || 0) * (item.quantity || 1)), 0);
};

// Get item count
window.getCartItemCount = function() {
  const items = window.getCart();
  return items.reduce((sum, item) => sum + (item.quantity || 1), 0);
};

// Initialize on page load
window.updateCartCount();
console.log('🛒 Cart ready. Items:', window.getCart().length);
</script>

