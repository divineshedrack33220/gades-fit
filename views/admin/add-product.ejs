<%- include('partials/admin-header') %>

<div class="admin-form enterprise-form">
  <div class="form-header">
    <h2>Add New Product</h2>
    <p class="form-subtitle">Fill in the details below to add a new product to your catalog</p>
  </div>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <span>❌</span> <%= error %>
    </div>
  <% } %>
  
  <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="product-form" id="productForm">
    
    <!-- Basic Information Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">📋</span>
        Basic Information
      </h3>
      
      <div class="form-row">
        <div class="form-group">
          <label>
            Product Name <span class="required">*</span>
            <span class="label-hint">Max 100 characters</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">📦</span>
            <input type="text" name="name" id="productName" placeholder="e.g., Olive Blazer" maxlength="100" required>
          </div>
          <div class="char-counter">
            <span id="nameCounter">0</span>/100
          </div>
        </div>
        <div class="form-group">
          <label>
            Price (₦) <span class="required">*</span>
            <span class="label-hint">Enter amount in Naira</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">₦</span>
            <input type="number" name="price" id="productPrice" placeholder="0.00" min="0" step="100" required>
          </div>
          <div class="price-preview" id="pricePreview"></div>
        </div>
      </div>
    </div>
    
    <!-- Category & Rating Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">🏷️</span>
        Category & Rating
      </h3>
      
      <div class="form-row">
        <div class="form-group">
          <label>
            Category <span class="required">*</span>
            <span class="label-hint">Select product category</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">📂</span>
            <select name="category" id="productCategory" required>
              <option value="">-- Select Category --</option>
              <option value="Classy">✨ Classy - Elegant & Sophisticated</option>
              <option value="Modern">🔥 Modern - Trendy & Contemporary</option>
              <option value="Comfy">☁️ Comfy - Relaxed & Cozy</option>
              <option value="Accessories">💎 Accessories - Bags, Jewelry & More</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>
            Comfy Rating
            <span class="label-hint">How comfortable is this item?</span>
          </label>
          <div class="rating-selector">
            <select name="comfyRating" id="comfyRating" class="rating-select">
              <option value="5">★★★★★ (5) - Cloud-like comfort</option>
              <option value="4">★★★★☆ (4) - Very comfortable</option>
              <option value="3">★★★☆☆ (3) - Comfortable</option>
              <option value="2">★★☆☆☆ (2) - Somewhat comfortable</option>
              <option value="1">★☆☆☆☆ (1) - Style over comfort</option>
            </select>
            <div class="rating-preview" id="ratingPreview">
              <span class="stars">★★★★★</span>
              <span class="rating-text">Cloud-like comfort</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Description Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">📝</span>
        Description
      </h3>
      
      <div class="form-group">
        <label>
          Product Description
          <span class="label-hint">Describe your product in detail</span>
        </label>
        <textarea name="description" id="productDescription" rows="5" placeholder="e.g., Handmade olive blazer with premium fabric. Perfect for both casual and formal occasions..."></textarea>
        <div class="char-counter">
          <span id="descCounter">0</span>/2000
        </div>
      </div>
    </div>
    
    <!-- Variants Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">🎨</span>
        Variants
      </h3>
      
      <div class="form-row">
        <div class="form-group">
          <label>
            Colors
            <span class="label-hint">Comma separated (e.g., Olive, Black, Brown)</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">🎨</span>
            <input type="text" name="colors" id="productColors" placeholder="Olive, Black, Brown">
          </div>
          <div class="color-preview" id="colorPreview"></div>
        </div>
        <div class="form-group">
          <label>
            Sizes
            <span class="label-hint">Comma separated (e.g., XS, S, M, L, XL)</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">📏</span>
            <input type="text" name="sizes" id="productSizes" placeholder="XS, S, M, L, XL">
          </div>
          <div class="size-preview" id="sizePreview"></div>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label>
            Tags
            <span class="label-hint">Comma separated keywords for search</span>
          </label>
          <div class="input-wrapper">
            <span class="input-icon">🏷️</span>
            <input type="text" name="tags" id="productTags" placeholder="e.g., handmade, premium, limited">
          </div>
          <div class="tags-preview" id="tagsPreview"></div>
        </div>
      </div>
    </div>
    
    <!-- Image Upload Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">🖼️</span>
        Product Image
      </h3>
      
      <div class="form-group">
        <label>
          Main Product Image <span class="required">*</span>
          <span class="label-hint">Recommended size: 800x1000px. Max 5MB</span>
        </label>
        
        <div class="image-upload-area" id="imageUploadArea">
          <input type="file" name="image" id="productImage" accept="image/jpeg,image/jpg,image/png,image/webp" required hidden>
          <div class="upload-placeholder" onclick="document.getElementById('productImage').click()">
            <div class="upload-icon">📷</div>
            <p class="upload-text">Click to upload or drag & drop</p>
            <p class="upload-hint">JPG, PNG, WEBP (Max 5MB)</p>
          </div>
          <div class="image-preview" id="imagePreview" style="display: none;">
            <img id="previewImg" src="" alt="Preview">
            <button type="button" class="remove-image" onclick="removeImage()">✕</button>
          </div>
        </div>
        
        <div class="image-requirements">
          <p><strong>Image Requirements:</strong></p>
          <ul>
            <li>✓ Minimum resolution: 600x800 pixels</li>
            <li>✓ Maximum file size: 5MB</li>
            <li>✓ Supported formats: JPG, PNG, WEBP</li>
            <li>✓ Use high-quality images with good lighting</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Additional Options Section -->
    <div class="form-section">
      <h3 class="section-title">
        <span class="section-icon">⚙️</span>
        Additional Options
      </h3>
      
      <div class="options-grid">
        <div class="option-card">
          <label class="checkbox-label">
            <input type="checkbox" name="inStock" checked>
            <span class="checkbox-custom"></span>
            <div class="option-content">
              <strong>In Stock</strong>
              <small>Product is available for purchase</small>
            </div>
          </label>
        </div>
        
        <div class="option-card">
          <label class="checkbox-label">
            <input type="checkbox" name="featured">
            <span class="checkbox-custom"></span>
            <div class="option-content">
              <strong>Featured Product</strong>
              <small>Display on homepage and featured sections</small>
            </div>
          </label>
        </div>
      </div>
    </div>
    
    <!-- Form Actions -->
    <div class="form-actions">
      <a href="/admin/products" class="btn btn-outline btn-large">
        <span>←</span> Cancel
      </a>
      <button type="submit" class="btn btn-primary btn-large" id="submitBtn">
        <span>💾</span> Save Product
      </button>
    </div>
  </form>
</div>

<style>
/* Enterprise Form Styles */
.enterprise-form {
  max-width: 1000px;
  margin: 0 auto;
}

.form-header {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 2px solid var(--border-lighter);
}

.form-header h2 {
  font-size: 2rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 0.5rem;
}

.form-subtitle {
  color: var(--text-muted);
  font-size: 0.95rem;
}

/* Form Sections */
.form-section {
  background: white;
  border-radius: 16px;
  padding: 2rem;
  margin-bottom: 2rem;
  border: 1px solid var(--border-lighter);
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 1.75rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-lighter);
}

.section-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, var(--olive-light), var(--olive));
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.2rem;
}

/* Form Groups */
.form-group {
  margin-bottom: 0;
}

.form-group label {
  display: block;
  margin-bottom: 0.5rem;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-dark);
}

.required {
  color: var(--danger);
  margin-left: 0.25rem;
}

.label-hint {
  display: block;
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--text-muted);
  margin-top: 0.25rem;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 1rem;
  color: var(--text-muted);
  font-size: 1rem;
  pointer-events: none;
}

.input-wrapper input,
.input-wrapper select,
.input-wrapper textarea {
  width: 100%;
  padding: 0.9rem 1rem 0.9rem 2.75rem;
  border: 2px solid var(--border-light);
  border-radius: 12px;
  font-family: var(--font-sans);
  font-size: 0.95rem;
  transition: var(--transition-fast);
  background: white;
}

textarea {
  padding-left: 1rem !important;
  resize: vertical;
  min-height: 120px;
}

.input-wrapper input:focus,
.input-wrapper select:focus,
.input-wrapper textarea:focus {
  outline: none;
  border-color: var(--olive);
  box-shadow: 0 0 0 4px rgba(45, 106, 79, 0.1);
}

/* Character Counter */
.char-counter {
  text-align: right;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.35rem;
}

.char-counter.warning {
  color: var(--warning);
}

.char-counter.danger {
  color: var(--danger);
}

/* Price Preview */
.price-preview {
  margin-top: 0.5rem;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--olive);
}

/* Rating Selector */
.rating-select {
  margin-bottom: 0.75rem;
}

.rating-preview {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.5rem 0;
}

.rating-preview .stars {
  font-size: 1.2rem;
  color: #FFB800;
  letter-spacing: 2px;
}

.rating-preview .rating-text {
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* Color Preview */
.color-preview,
.size-preview,
.tags-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.75rem;
}

.color-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0.75rem;
  background: var(--bg-gray);
  border-radius: 20px;
  font-size: 0.8rem;
}

.color-dot-preview {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.1);
}

.size-tag,
.tag-item {
  display: inline-block;
  padding: 0.35rem 0.75rem;
  background: var(--bg-gray);
  border-radius: 20px;
  font-size: 0.8rem;
}

/* Image Upload */
.image-upload-area {
  position: relative;
  border: 2px dashed var(--border-light);
  border-radius: 16px;
  padding: 2rem;
  text-align: center;
  transition: var(--transition-fast);
  cursor: pointer;
  background: var(--bg-gray);
}

.image-upload-area:hover {
  border-color: var(--olive);
  background: rgba(45, 106, 79, 0.02);
}

.image-upload-area.dragover {
  border-color: var(--olive);
  background: rgba(45, 106, 79, 0.05);
}

.upload-placeholder {
  cursor: pointer;
}

.upload-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.upload-text {
  font-size: 1rem;
  color: var(--text-dark);
  margin-bottom: 0.25rem;
}

.upload-hint {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.image-preview {
  position: relative;
  display: inline-block;
}

.image-preview img {
  max-width: 100%;
  max-height: 300px;
  border-radius: 12px;
  object-fit: cover;
}

.remove-image {
  position: absolute;
  top: -10px;
  right: -10px;
  width: 32px;
  height: 32px;
  background: var(--danger);
  color: white;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
}

.remove-image:hover {
  background: #dc2626;
}

.image-requirements {
  margin-top: 1rem;
  padding: 1rem;
  background: var(--bg-gray);
  border-radius: 12px;
}

.image-requirements p {
  margin-bottom: 0.5rem;
  font-size: 0.85rem;
}

.image-requirements ul {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.5rem;
}

.image-requirements li {
  font-size: 0.8rem;
  color: var(--text-muted);
}

/* Options Grid */
.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.option-card {
  padding: 1.25rem;
  background: var(--bg-gray);
  border-radius: 12px;
  border: 1px solid var(--border-lighter);
  transition: var(--transition-fast);
}

.option-card:hover {
  background: white;
  border-color: var(--olive);
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  cursor: pointer;
}

.checkbox-label input[type="checkbox"] {
  display: none;
}

.checkbox-custom {
  width: 22px;
  height: 22px;
  border: 2px solid var(--border-light);
  border-radius: 6px;
  position: relative;
  flex-shrink: 0;
  margin-top: 2px;
  transition: var(--transition-fast);
}

.checkbox-label input[type="checkbox"]:checked + .checkbox-custom {
  background: var(--olive);
  border-color: var(--olive);
}

.checkbox-label input[type="checkbox"]:checked + .checkbox-custom::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  font-size: 14px;
}

.option-content {
  display: flex;
  flex-direction: column;
}

.option-content strong {
  font-size: 0.95rem;
  margin-bottom: 0.25rem;
}

.option-content small {
  font-size: 0.8rem;
  color: var(--text-muted);
}

/* Form Actions */
.form-actions {
  display: flex;
  gap: 1rem;
  justify-content: flex-end;
  padding-top: 1rem;
}

.btn-large {
  padding: 1rem 2rem;
  font-size: 1rem;
}

/* Alert */
.alert {
  padding: 1rem 1.5rem;
  border-radius: 12px;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.alert-error {
  background: #FEE2E2;
  color: var(--danger);
  border: 1px solid #FECACA;
}

/* Responsive */
@media (max-width: 768px) {
  .form-section {
    padding: 1.5rem;
  }
  
  .form-row {
    grid-template-columns: 1fr !important;
    gap: 1rem !important;
  }
  
  .options-grid {
    grid-template-columns: 1fr;
  }
  
  .image-requirements ul {
    grid-template-columns: 1fr;
  }
  
  .form-actions {
    flex-direction: column-reverse;
  }
  
  .form-actions .btn {
    width: 100%;
  }
}
</style>

<script>
// Character counters
const nameInput = document.getElementById('productName');
const nameCounter = document.getElementById('nameCounter');
const descInput = document.getElementById('productDescription');
const descCounter = document.getElementById('descCounter');

function updateCounter(input, counter, max) {
  const length = input.value.length;
  counter.textContent = length;
  counter.parentElement.classList.remove('warning', 'danger');
  if (length > max * 0.8) counter.parentElement.classList.add('warning');
  if (length > max) counter.parentElement.classList.add('danger');
}

nameInput.addEventListener('input', () => updateCounter(nameInput, nameCounter, 100));
descInput.addEventListener('input', () => updateCounter(descInput, descCounter, 2000));
updateCounter(nameInput, nameCounter, 100);
updateCounter(descInput, descCounter, 2000);

// Price preview
const priceInput = document.getElementById('productPrice');
const pricePreview = document.getElementById('pricePreview');
priceInput.addEventListener('input', () => {
  const price = parseFloat(priceInput.value) || 0;
  pricePreview.textContent = price > 0 ? `₦${price.toLocaleString()}` : '';
});

// Rating preview
const ratingSelect = document.getElementById('comfyRating');
const ratingPreview = document.querySelector('.rating-preview');
ratingSelect.addEventListener('change', function() {
  const rating = parseInt(this.value);
  const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);
  const texts = ['Style over comfort', 'Somewhat comfortable', 'Comfortable', 'Very comfortable', 'Cloud-like comfort'];
  ratingPreview.querySelector('.stars').textContent = stars;
  ratingPreview.querySelector('.rating-text').textContent = texts[rating - 1];
});

// Colors preview
const colorsInput = document.getElementById('productColors');
const colorPreview = document.getElementById('colorPreview');
const colorMap = {
  'olive': '#7A8257', 'black': '#000000', 'brown': '#8B4513',
  'white': '#FFFFFF', 'red': '#FF0000', 'blue': '#0000FF',
  'green': '#00FF00', 'yellow': '#FFFF00', 'purple': '#800080',
  'pink': '#FFC0CB', 'gray': '#808080', 'grey': '#808080',
  'navy': '#000080', 'beige': '#F5F5DC', 'burgundy': '#6B1A2A',
  'butter': '#F5E6B8', 'sage': '#9CAF88'
};
colorsInput.addEventListener('input', function() {
  const colors = this.value.split(',').map(c => c.trim()).filter(c => c);
  colorPreview.innerHTML = colors.map(color => {
    const colorKey = color.toLowerCase();
    const bgColor = colorMap[colorKey] || '#ccc';
    return `<span class="color-tag"><span class="color-dot-preview" style="background: ${bgColor};"></span>${color}</span>`;
  }).join('');
});

// Sizes preview
const sizesInput = document.getElementById('productSizes');
const sizePreview = document.getElementById('sizePreview');
sizesInput.addEventListener('input', function() {
  const sizes = this.value.split(',').map(s => s.trim()).filter(s => s);
  sizePreview.innerHTML = sizes.map(size => `<span class="size-tag">${size}</span>`).join('');
});

// Tags preview
const tagsInput = document.getElementById('productTags');
const tagsPreview = document.getElementById('tagsPreview');
tagsInput.addEventListener('input', function() {
  const tags = this.value.split(',').map(t => t.trim()).filter(t => t);
  tagsPreview.innerHTML = tags.map(tag => `<span class="tag-item">#${tag}</span>`).join('');
});

// Image upload
const imageInput = document.getElementById('productImage');
const uploadArea = document.getElementById('imageUploadArea');
const placeholder = document.querySelector('.upload-placeholder');
const preview = document.getElementById('imagePreview');
const previewImg = document.getElementById('previewImg');

imageInput.addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (file) {
    if (file.size > 5 * 1024 * 1024) {
      alert('File size exceeds 5MB. Please choose a smaller file.');
      imageInput.value = '';
      return;
    }
    
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target.result;
      placeholder.style.display = 'none';
      preview.style.display = 'inline-block';
    };
    reader.readAsDataURL(file);
  }
});

function removeImage() {
  imageInput.value = '';
  placeholder.style.display = 'block';
  preview.style.display = 'none';
  previewImg.src = '';
}

// Drag and drop
uploadArea.addEventListener('dragover', (e) => {
  e.preventDefault();
  uploadArea.classList.add('dragover');
});

uploadArea.addEventListener('dragleave', () => {
  uploadArea.classList.remove('dragover');
});

uploadArea.addEventListener('drop', (e) => {
  e.preventDefault();
  uploadArea.classList.remove('dragover');
  
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) {
    if (file.size > 5 * 1024 * 1024) {
      alert('File size exceeds 5MB.');
      return;
    }
    imageInput.files = e.dataTransfer.files;
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target.result;
      placeholder.style.display = 'none';
      preview.style.display = 'inline-block';
    };
    reader.readAsDataURL(file);
  }
});

// Form validation
document.getElementById('productForm').addEventListener('submit', function(e) {
  const name = document.getElementById('productName').value.trim();
  const price = document.getElementById('productPrice').value;
  const category = document.getElementById('productCategory').value;
  const image = document.getElementById('productImage').files[0];
  
  let errors = [];
  if (!name) errors.push('Product name is required');
  if (!price || parseFloat(price) <= 0) errors.push('Valid price is required');
  if (!category) errors.push('Category is required');
  if (!image) errors.push('Product image is required');
  
  if (errors.length > 0) {
    e.preventDefault();
    alert('Please fix the following errors:\n- ' + errors.join('\n- '));
  } else {
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<span>⏳</span> Saving...';
    btn.disabled = true;
  }
});
</script>

<%- include('partials/admin-footer') %>