<%- include('partials/admin-header') %>

<div class="admin-settings enterprise">
  <div class="settings-header">
    <div class="header-left">
      <h2>Site Settings</h2>
      <p class="header-subtitle">Configure your website content and preferences</p>
    </div>
    <div class="header-right">
      <button class="btn btn-outline" onclick="previewSettings()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        Preview
      </button>
      <button class="btn btn-primary" onclick="saveSettings()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
        Save All Changes
      </button>
    </div>
  </div>
  
  <!-- Alerts -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success" role="alert">
      <span class="alert-icon">✓</span>
      <span class="alert-message"><%= success %></span>
      <button class="alert-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error" role="alert">
      <span class="alert-icon">!</span>
      <span class="alert-message"><%= error %></span>
      <button class="alert-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
  
  <form id="settingsForm" method="POST" action="/admin/settings" enctype="multipart/form-data">
    <input type="hidden" name="settings" id="settingsJson">
    
    <!-- Settings Tabs -->
    <div class="settings-tabs-wrapper">
      <div class="settings-tabs">
        <button type="button" class="settings-tab active" data-tab="hero">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Hero
        </button>
        <button type="button" class="settings-tab" data-tab="categories">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
          </svg>
          Categories
        </button>
        <button type="button" class="settings-tab" data-tab="about">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          About
        </button>
        <button type="button" class="settings-tab" data-tab="contact">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8 10a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.574 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Contact
        </button>
        <button type="button" class="settings-tab" data-tab="newsletter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Newsletter
        </button>
      </div>
    </div>
    
    <div class="settings-panels">
      <!-- Hero Tab -->
      <div id="panel-hero" class="settings-panel active">
        <div class="panel-header">
          <h3>Hero Section</h3>
          <p class="panel-desc">Configure the main hero banner displayed on the homepage</p>
        </div>
        
        <div class="form-grid">
          <div class="form-group full-width">
            <label>Badge Text</label>
            <input type="text" id="heroBadge" value="<%= settings.hero.badge %>" class="form-control" placeholder="e.g., New Collection">
            <span class="field-hint">Small text displayed above the title</span>
          </div>
          
          <div class="form-group full-width">
            <label>Title</label>
            <textarea id="heroTitle" rows="3" class="form-control" placeholder="Classy.\nModern.\nComfy."><%= settings.hero.title %></textarea>
            <span class="field-hint">Use \n for line breaks</span>
          </div>
          
          <div class="form-group full-width">
            <label>Subtitle</label>
            <input type="text" id="heroSubtitle" value="<%= settings.hero.subtitle %>" class="form-control" placeholder="Handmade accessories & quality clothing...">
          </div>
          
          <div class="form-group full-width">
            <label>Trust Badges</label>
            <textarea id="heroTrustBadges" rows="3" class="form-control" placeholder="Free Shipping over ₦50k&#10;Handmade in Lagos&#10;7-Day Returns"><%= settings.hero.trustBadges.join('\n') %></textarea>
            <span class="field-hint">One badge per line</span>
          </div>
        </div>
      </div>
      
      <!-- Categories Tab -->
      <div id="panel-categories" class="settings-panel">
        <div class="panel-header">
          <h3>Category Sections</h3>
          <p class="panel-desc">Manage the category cards displayed on the homepage</p>
        </div>
        
        <div class="categories-container">
          <% settings.categories.forEach(function(cat, index) { %>
            <div class="category-card-settings">
              <div class="category-header">
                <span class="category-number"><%= index + 1 %></span>
                <h4>Category <%= index + 1 %></h4>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Name</label>
                  <input type="text" class="cat-name form-control" value="<%= cat.name %>" data-index="<%= index %>" placeholder="e.g., Classy">
                </div>
                <div class="form-group">
                  <label>Image URL</label>
                  <input type="text" class="cat-image form-control" value="<%= cat.image %>" data-index="<%= index %>" placeholder="https://...">
                </div>
                <div class="form-group">
                  <label>Link</label>
                  <input type="text" class="cat-link form-control" value="<%= cat.link %>" data-index="<%= index %>" placeholder="/products?cat=Classy">
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
      
      <!-- About Tab -->
      <div id="panel-about" class="settings-panel">
        <div class="panel-header">
          <h3>About Page Content</h3>
          <p class="panel-desc">Configure the about page content and brand story</p>
        </div>
        
        <div class="form-section">
          <h4>Hero Section</h4>
          <div class="form-grid">
            <div class="form-group full-width">
              <label>Hero Title</label>
              <input type="text" id="aboutHeroTitle" value="<%= settings.about.heroTitle %>" class="form-control">
            </div>
            <div class="form-group full-width">
              <label>Hero Subtitle</label>
              <input type="text" id="aboutHeroSubtitle" value="<%= settings.about.heroSubtitle %>" class="form-control">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Founder Information</h4>
          <div class="form-grid">
            <div class="form-group">
              <label>Founder Name</label>
              <input type="text" id="aboutFounderName" value="<%= settings.about.founderName %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Founder Title</label>
              <input type="text" id="aboutFounderTitle" value="<%= settings.about.founderTitle %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Founder Image URL</label>
              <input type="text" id="aboutFounderImage" value="<%= settings.about.founderImage %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Studio Image URL</label>
              <input type="text" id="aboutStudioImage" value="<%= settings.about.studioImage %>" class="form-control">
            </div>
            <div class="form-group full-width">
              <label>Founder Story</label>
              <textarea id="aboutFounderStory" rows="4" class="form-control"><%= settings.about.founderStory.join('\n\n') %></textarea>
              <span class="field-hint">Separate paragraphs with a blank line</span>
            </div>
            <div class="form-group full-width">
              <label>Quote</label>
              <textarea id="aboutQuote" rows="2" class="form-control"><%= settings.about.quote %></textarea>
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Brand Promise</h4>
          <div class="form-grid">
            <div class="form-group full-width">
              <label>Promise Title</label>
              <input type="text" id="aboutPromiseTitle" value="<%= settings.about.promiseTitle %>" class="form-control">
            </div>
            <div class="form-group full-width">
              <label>Promise Text</label>
              <textarea id="aboutPromiseText" rows="3" class="form-control"><%= settings.about.promiseText.join('\n\n') %></textarea>
            </div>
            <div class="form-group">
              <label>Signature</label>
              <input type="text" id="aboutSignature" value="<%= settings.about.signature %>" class="form-control">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Brand Values</h4>
          <div class="values-container">
            <% settings.about.values.forEach(function(val, index) { %>
              <div class="value-card-settings">
                <div class="value-header">
                  <span class="value-number"><%= index + 1 %></span>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label>Icon</label>
                    <input type="text" class="value-icon form-control" value="<%= val.icon %>" data-index="<%= index %>" placeholder="✧">
                  </div>
                  <div class="form-group">
                    <label>Title</label>
                    <input type="text" class="value-title form-control" value="<%= val.title %>" data-index="<%= index %>" placeholder="Quality First">
                  </div>
                  <div class="form-group full-width">
                    <label>Description</label>
                    <input type="text" class="value-desc form-control" value="<%= val.description %>" data-index="<%= index %>">
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
      
      <!-- Contact Tab -->
      <div id="panel-contact" class="settings-panel">
        <div class="panel-header">
          <h3>Contact Information</h3>
          <p class="panel-desc">Manage contact details displayed on the contact page</p>
        </div>
        
        <div class="form-section">
          <h4>Studio Location</h4>
          <div class="form-grid">
            <div class="form-group full-width">
              <label>Address</label>
              <input type="text" id="contactStudioAddress" value="<%= settings.contact.studio.address %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Note</label>
              <input type="text" id="contactStudioNote" value="<%= settings.contact.studio.note %>" class="form-control" placeholder="By appointment only">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Phone Numbers</h4>
          <div class="form-row">
            <div class="form-group">
              <label>Primary Phone</label>
              <input type="text" id="contactPhonePrimary" value="<%= settings.contact.phone.primary %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Secondary Phone</label>
              <input type="text" id="contactPhoneSecondary" value="<%= settings.contact.phone.secondary %>" class="form-control">
            </div>
            <div class="form-group full-width">
              <label>Business Hours</label>
              <input type="text" id="contactPhoneHours" value="<%= settings.contact.phone.hours %>" class="form-control">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Email Addresses</h4>
          <div class="form-row">
            <div class="form-group">
              <label>Primary Email</label>
              <input type="text" id="contactEmailPrimary" value="<%= settings.contact.email.primary %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Wholesale Email</label>
              <input type="text" id="contactEmailWholesale" value="<%= settings.contact.email.wholesale %>" class="form-control">
            </div>
            <div class="form-group full-width">
              <label>Response Time</label>
              <input type="text" id="contactEmailResponse" value="<%= settings.contact.email.response %>" class="form-control">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Social Media</h4>
          <div class="form-row">
            <div class="form-group">
              <label>Instagram URL</label>
              <input type="text" id="contactSocialInstagram" value="<%= settings.contact.social.instagram %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Facebook URL</label>
              <input type="text" id="contactSocialFacebook" value="<%= settings.contact.social.facebook %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Pinterest URL</label>
              <input type="text" id="contactSocialPinterest" value="<%= settings.contact.social.pinterest %>" class="form-control">
            </div>
          </div>
        </div>
      </div>
      
      <!-- Newsletter Tab -->
      <div id="panel-newsletter" class="settings-panel">
        <div class="panel-header">
          <h3>Newsletter & Instagram</h3>
          <p class="panel-desc">Configure newsletter signup and Instagram integration</p>
        </div>
        
        <div class="form-section">
          <h4>Newsletter Settings</h4>
          <div class="form-grid">
            <div class="form-group full-width">
              <label>Title</label>
              <input type="text" id="newsletterTitle" value="<%= settings.newsletter.title %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Subtitle (Discount Text)</label>
              <input type="text" id="newsletterSubtitle" value="<%= settings.newsletter.subtitle %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Input Placeholder</label>
              <input type="text" id="newsletterPlaceholder" value="<%= settings.newsletter.placeholder %>" class="form-control">
            </div>
          </div>
        </div>
        
        <div class="form-section">
          <h4>Instagram Settings</h4>
          <div class="form-row">
            <div class="form-group">
              <label>Instagram Handle</label>
              <input type="text" id="instagramHandle" value="<%= settings.instagram.handle %>" class="form-control" placeholder="@gades_fit">
            </div>
            <div class="form-group">
              <label>Tagline</label>
              <input type="text" id="instagramTagline" value="<%= settings.instagram.tagline %>" class="form-control">
            </div>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<style>
/* Enterprise Settings Page */
.enterprise {
  max-width: 1000px;
  margin: 0 auto;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.header-left h2 {
  font-size: 1.8rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 0.25rem;
}

.header-subtitle {
  color: var(--text-muted);
  font-size: 0.9rem;
}

.header-right {
  display: flex;
  gap: 0.75rem;
}

/* Alerts */
.alert {
  padding: 14px 20px;
  margin-bottom: 24px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.alert-success {
  background: #d4edda;
  color: #155724;
  border: 1px solid #c3e6cb;
}

.alert-error {
  background: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

.alert-icon {
  font-weight: 700;
  font-size: 18px;
}

.alert-message {
  flex: 1;
}

.alert-close {
  background: none;
  border: none;
  font-size: 20px;
  cursor: pointer;
  opacity: 0.5;
}

/* Settings Tabs */
.settings-tabs-wrapper {
  border-bottom: 1px solid var(--border-lighter);
  margin-bottom: 2rem;
}

.settings-tabs {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.settings-tab {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 20px;
  background: none;
  border: none;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  border-bottom: 3px solid transparent;
  transition: all 0.2s;
  margin-bottom: -1px;
}

.settings-tab:hover {
  color: var(--olive);
  background: var(--bg-gray);
}

.settings-tab.active {
  color: var(--olive);
  border-bottom-color: var(--olive);
}

/* Settings Panels */
.settings-panel {
  display: none;
  animation: fadeIn 0.3s ease;
}

.settings-panel.active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(5px); }
  to { opacity: 1; transform: translateY(0); }
}

.panel-header {
  margin-bottom: 2rem;
}

.panel-header h3 {
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 0.25rem;
}

.panel-desc {
  color: var(--text-muted);
  font-size: 0.9rem;
}

/* Form Sections */
.form-section {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border-lighter);
}

.form-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.form-section h4 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 1.25rem;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-group.full-width {
  grid-column: span 2;
}

.form-group label {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-dark);
  margin-bottom: 0.5rem;
}

.field-hint {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.35rem;
}

.form-control {
  padding: 10px 14px;
  border: 1px solid var(--border-light);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-sans);
  background: white;
  transition: all 0.2s;
}

.form-control:focus {
  outline: none;
  border-color: var(--olive);
  box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.1);
}

textarea.form-control {
  resize: vertical;
  min-height: 80px;
}

/* Category Cards */
.categories-container {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.category-card-settings {
  background: var(--bg-gray);
  border-radius: 12px;
  padding: 1.25rem;
  border: 1px solid var(--border-lighter);
}

.category-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 1rem;
}

.category-number {
  width: 28px;
  height: 28px;
  background: var(--olive);
  color: white;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 14px;
}

.category-header h4 {
  margin: 0;
  font-size: 1rem;
}

/* Value Cards */
.values-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.value-card-settings {
  background: var(--bg-gray);
  border-radius: 12px;
  padding: 1.25rem;
  border: 1px solid var(--border-lighter);
}

.value-header {
  margin-bottom: 1rem;
}

.value-number {
  width: 28px;
  height: 28px;
  background: var(--olive);
  color: white;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 14px;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  border: 1px solid transparent;
}

.btn-primary {
  background: var(--olive);
  color: white;
  border-color: var(--olive);
}

.btn-primary:hover {
  background: var(--olive-dark);
}

.btn-outline {
  background: transparent;
  border-color: var(--border-light);
  color: var(--text-dark);
}

.btn-outline:hover {
  background: var(--bg-gray);
  border-color: var(--olive);
}

/* Responsive */
@media (max-width: 768px) {
  .settings-header {
    flex-direction: column;
  }
  
  .header-right {
    width: 100%;
  }
  
  .header-right .btn {
    flex: 1;
    justify-content: center;
  }
  
  .settings-tabs {
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 8px;
  }
  
  .settings-tab {
    white-space: nowrap;
  }
  
  .form-grid,
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .form-group.full-width {
    grid-column: span 1;
  }
}
</style>

<script>
let settings = <%- JSON.stringify(settings) %>;

// Tab switching
document.querySelectorAll('.settings-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    const tabName = this.dataset.tab;
    
    document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.settings-panel').forEach(p => p.classList.remove('active'));
    
    this.classList.add('active');
    document.getElementById('panel-' + tabName).classList.add('active');
  });
});

function collectSettings() {
  // Hero
  settings.hero.badge = document.getElementById('heroBadge').value;
  settings.hero.title = document.getElementById('heroTitle').value;
  settings.hero.subtitle = document.getElementById('heroSubtitle').value;
  settings.hero.trustBadges = document.getElementById('heroTrustBadges').value.split('\n').filter(s => s.trim());
  
  // Categories
  document.querySelectorAll('.cat-name').forEach((el, i) => { if (settings.categories[i]) settings.categories[i].name = el.value; });
  document.querySelectorAll('.cat-image').forEach((el, i) => { if (settings.categories[i]) settings.categories[i].image = el.value; });
  document.querySelectorAll('.cat-link').forEach((el, i) => { if (settings.categories[i]) settings.categories[i].link = el.value; });
  
  // About
  settings.about.heroTitle = document.getElementById('aboutHeroTitle').value;
  settings.about.heroSubtitle = document.getElementById('aboutHeroSubtitle').value;
  settings.about.founderImage = document.getElementById('aboutFounderImage').value;
  settings.about.studioImage = document.getElementById('aboutStudioImage').value;
  settings.about.founderName = document.getElementById('aboutFounderName').value;
  settings.about.founderTitle = document.getElementById('aboutFounderTitle').value;
  settings.about.founderStory = document.getElementById('aboutFounderStory').value.split('\n\n').filter(s => s.trim());
  settings.about.quote = document.getElementById('aboutQuote').value;
  settings.about.promiseTitle = document.getElementById('aboutPromiseTitle').value;
  settings.about.promiseText = document.getElementById('aboutPromiseText').value.split('\n\n').filter(s => s.trim());
  settings.about.signature = document.getElementById('aboutSignature').value;
  
  document.querySelectorAll('.value-icon').forEach((el, i) => { if (settings.about.values[i]) settings.about.values[i].icon = el.value; });
  document.querySelectorAll('.value-title').forEach((el, i) => { if (settings.about.values[i]) settings.about.values[i].title = el.value; });
  document.querySelectorAll('.value-desc').forEach((el, i) => { if (settings.about.values[i]) settings.about.values[i].description = el.value; });
  
  // Contact
  settings.contact.studio.address = document.getElementById('contactStudioAddress').value;
  settings.contact.studio.note = document.getElementById('contactStudioNote').value;
  settings.contact.phone.primary = document.getElementById('contactPhonePrimary').value;
  settings.contact.phone.secondary = document.getElementById('contactPhoneSecondary').value;
  settings.contact.phone.hours = document.getElementById('contactPhoneHours').value;
  settings.contact.email.primary = document.getElementById('contactEmailPrimary').value;
  settings.contact.email.wholesale = document.getElementById('contactEmailWholesale').value;
  settings.contact.email.response = document.getElementById('contactEmailResponse').value;
  settings.contact.social.instagram = document.getElementById('contactSocialInstagram').value;
  settings.contact.social.facebook = document.getElementById('contactSocialFacebook').value;
  settings.contact.social.pinterest = document.getElementById('contactSocialPinterest').value;
  
  // Newsletter
  settings.newsletter.title = document.getElementById('newsletterTitle').value;
  settings.newsletter.subtitle = document.getElementById('newsletterSubtitle').value;
  settings.newsletter.placeholder = document.getElementById('newsletterPlaceholder').value;
  settings.instagram.handle = document.getElementById('instagramHandle').value;
  settings.instagram.tagline = document.getElementById('instagramTagline').value;
}

function saveSettings() {
  collectSettings();
  document.getElementById('settingsJson').value = JSON.stringify(settings);
  document.getElementById('settingsForm').submit();
}

function previewSettings() {
  alert('Preview feature - opens site in new tab');
  window.open('/', '_blank');
}

// Auto-hide alerts
document.querySelectorAll('.alert').forEach(alert => {
  setTimeout(() => {
    alert.style.transition = 'opacity 0.3s';
    alert.style.opacity = '0';
    setTimeout(() => alert.remove(), 300);
  }, 5000);
});
</script>

