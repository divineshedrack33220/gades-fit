<%- include('partials/admin-header') %>

<div class="admin-contacts enterprise">
  
  <!-- Header -->
  <div class="contacts-header">
    <div class="header-left">
      <h2>Contact Messages</h2>
      <p class="header-subtitle">View and manage customer inquiries</p>
    </div>
    <div class="header-right">
      <div class="unread-badge" id="unreadBadge" style="display: none;">
        <span class="unread-count" id="unreadCount">0</span> unread
      </div>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="filter-bar-enterprise">
    <div class="search-wrapper">
      <span class="search-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </span>
      <input type="text" 
             id="contactSearch" 
             class="search-input" 
             placeholder="Search by name, email, or subject..." 
             aria-label="Search messages">
      <button class="clear-search" id="clearSearch" type="button" style="display: none;">×</button>
    </div>
    
    <div class="filter-actions">
      <select id="statusFilter" class="filter-select">
        <option value="all">All Messages</option>
        <option value="unread">Unread</option>
        <option value="read">Read</option>
        <option value="replied">Replied</option>
      </select>
      
      <button class="btn btn-outline" id="resetFilters">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
          <path d="M3 3v5h5"/>
        </svg>
        Reset
      </button>
    </div>
  </div>

  <!-- Status Tabs -->
  <div class="status-tabs">
    <button class="status-tab active" data-status="all">
      <span class="tab-label">All Messages</span>
      <span class="tab-count"><%= contacts.length %></span>
    </button>
    <button class="status-tab" data-status="unread">
      <span class="tab-label">Unread</span>
      <span class="tab-count unread"><%= contacts.filter(c => c.status === 'unread').length %></span>
    </button>
    <button class="status-tab" data-status="read">
      <span class="tab-label">Read</span>
      <span class="tab-count read"><%= contacts.filter(c => c.status === 'read').length %></span>
    </button>
    <button class="status-tab" data-status="replied">
      <span class="tab-label">Replied</span>
      <span class="tab-count replied"><%= contacts.filter(c => c.status === 'replied').length %></span>
    </button>
  </div>
  
  <!-- Alerts -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success" role="alert">
      <span class="alert-icon">✓</span>
      <span class="alert-message"><%= success %></span>
      <button class="alert-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error" role="alert">
      <span class="alert-icon">!</span>
      <span class="alert-message"><%= error %></span>
      <button class="alert-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
  
  <% if (contacts && contacts.length > 0) { %>
    <div class="table-responsive">
      <table class="enterprise-table" id="contactsTable">
        <thead>
          <tr>
            <th style="width: 40px;">
              <input type="checkbox" id="selectAll" class="checkbox-enterprise">
            </th>
            <th>Status</th>
            <th>Name</th>
            <th>Email</th>
            <th>Subject</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% contacts.forEach(function(contact) { %>
            <tr class="contact-row <%= contact.status === 'unread' ? 'row-unread' : '' %>" 
                data-id="<%= contact._id %>"
                data-name="<%= contact.name.toLowerCase() %>"
                data-email="<%= contact.email.toLowerCase() %>"
                data-subject="<%= contact.subject.toLowerCase() %>"
                data-status="<%= contact.status %>">
              <td>
                <input type="checkbox" class="contact-checkbox checkbox-enterprise" value="<%= contact._id %>">
              </td>
              <td>
                <% if (contact.status === 'unread') { %>
                  <span class="status-badge warning">
                    <span class="status-dot"></span>
                    Unread
                  </span>
                <% } else if (contact.status === 'read') { %>
                  <span class="status-badge info">
                    <span class="status-dot"></span>
                    Read
                  </span>
                <% } else if (contact.status === 'replied') { %>
                  <span class="status-badge success">
                    <span class="status-dot"></span>
                    Replied
                  </span>
                <% } else { %>
                  <span class="status-badge"><%= contact.status %></span>
                <% } %>
              </td>
              <td>
                <div class="name-cell">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="name-icon">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                  <strong><%= contact.name %></strong>
                </div>
              </td>
              <td>
                <span class="email-address"><%= contact.email %></span>
              </td>
              <td>
                <span class="subject-text"><%= contact.subject %></span>
              </td>
              <td>
                <span class="message-date">
                  <%= contact.createdAt ? new Date(contact.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %>
                </span>
              </td>
              <td>
                <div class="action-buttons">
                  <a href="/admin/contacts/<%= contact._id %>" class="action-btn-icon" title="View Message">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                  </a>
                  <a href="mailto:<%= contact.email %>" class="action-btn-icon" title="Reply via Email">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 11.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7.5"/>
                      <polyline points="16 2 22 8 16 8"/>
                      <line x1="10" y1="14" x2="21" y2="14"/>
                      <line x1="10" y1="18" x2="18" y2="18"/>
                      <line x1="3" y1="10" x2="8" y2="10"/>
                    </svg>
                  </a>
                  <form action="/admin/contacts/<%= contact._id %>/delete" method="POST" class="delete-form">
                    <button type="submit" 
                            class="action-btn-icon" 
                            title="Delete"
                            onclick="return confirm('Delete this message permanently?')">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 6h18"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    
    <!-- Bulk Actions Bar -->
    <div class="bulk-actions" id="bulkActions" style="display: none;">
      <span class="selected-count"><span id="selectedCount">0</span> selected</span>
      <div class="bulk-buttons">
        <button class="btn btn-outline btn-sm" onclick="bulkMarkRead()">Mark as Read</button>
        <button class="btn btn-outline btn-sm" onclick="bulkMarkReplied()">Mark as Replied</button>
        <button class="btn btn-danger btn-sm" onclick="bulkDelete()">Delete Selected</button>
      </div>
      <button class="bulk-close" onclick="clearSelection()">×</button>
    </div>
    
    <!-- Simple Footer -->
    <div class="table-footer-simple">
      <span><strong><%= contacts.length %></strong> total messages</span>
      <span class="separator">•</span>
      <span class="unread-count-footer"><strong><%= contacts.filter(c => c.status === 'unread').length %></strong> unread</span>
      <span class="separator">•</span>
      <span class="replied-count-footer"><strong><%= contacts.filter(c => c.status === 'replied').length %></strong> replied</span>
    </div>
    
    <!-- Pagination -->
    <% if (typeof pagination !== 'undefined' && pagination.pages > 1) { %>
      <div class="pagination-enterprise">
        <a href="?page=1" class="page-btn <%= pagination.page === 1 ? 'disabled' : '' %>">«</a>
        <a href="?page=<%= Math.max(1, pagination.page - 1) %>" class="page-btn <%= pagination.page === 1 ? 'disabled' : '' %>">‹</a>
        
        <% for (var i = Math.max(1, pagination.page - 2); i <= Math.min(pagination.pages, pagination.page + 2); i++) { %>
          <a href="?page=<%= i %>" class="page-btn <%= i === pagination.page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        
        <a href="?page=<%= Math.min(pagination.pages, pagination.page + 1) %>" class="page-btn <%= pagination.page === pagination.pages ? 'disabled' : '' %>">›</a>
        <a href="?page=<%= pagination.pages %>" class="page-btn <%= pagination.page === pagination.pages ? 'disabled' : '' %>">»</a>
      </div>
    <% } %>
    
  <% } else { %>
    <div class="empty-state-enterprise">
      <div class="empty-illustration">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <h3>No Contact Messages Yet</h3>
      <p>When customers send inquiries, they'll appear here.</p>
    </div>
  <% } %>
</div>

<style>
