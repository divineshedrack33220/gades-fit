    <!-- Main Content -->
    <main class="admin-main">

<!-- Active Page Highlighting Script -->
<script>
(function() {
  'use strict';
  
  // Get current path
  const currentPath = window.location.pathname;
  
  // Remove any existing active classes
  function removeActiveClasses() {
    document.querySelectorAll('.sidebar-nav a').forEach(link => {
      link.classList.remove('active');
    });
  }
  
  // Add active class based on current path
  function highlightCurrentPage() {
    removeActiveClasses();
    
    // Dashboard
    if (currentPath === '/admin/dashboard' || currentPath === '/admin') {
      document.getElementById('nav-dashboard')?.classList.add('active');
    }
    // Products (including add/edit pages)
    else if (currentPath.startsWith('/admin/products')) {
      document.getElementById('nav-products')?.classList.add('active');
    }
    // Orders (including details page)
    else if (currentPath.startsWith('/admin/orders')) {
      document.getElementById('nav-orders')?.classList.add('active');
    }
    // Contacts/Messages
    else if (currentPath.startsWith('/admin/contacts')) {
      document.getElementById('nav-contacts')?.classList.add('active');
    }
    // Subscribers
    else if (currentPath.startsWith('/admin/subscribers')) {
      document.getElementById('nav-subscribers')?.classList.add('active');
    }
    // Settings
    else if (currentPath.startsWith('/admin/settings')) {
      document.getElementById('nav-settings')?.classList.add('active');
    }
  }
  
  // Initialize highlighting
  highlightCurrentPage();
  
  // Also handle clicks for single-page app feel (optional)
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    link.addEventListener('click', function(e) {
      // Only if it's an internal admin link
      if (this.href && this.href.includes('/admin/')) {
        // Visual feedback - immediate highlight
        removeActiveClasses();
        this.classList.add('active');
      }
    });
  });
  
})();
</script>